APP_NAME="Yaiza Translate"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://translate.grupoyaiza.es

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ---- Database (MariaDB on the VPS — create it in CyberPanel first) ----
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yaizatranslate
DB_USERNAME=yaizatranslate
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=25
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@grupoyaiza.es"
MAIL_FROM_NAME="${APP_NAME}"

# ---- Translation engine ----
# Browser (Web Speech API) handles STT/TTS on-device for the free tier.
# The text translation step is proxied through this provider:
TRANSLATOR_ENGINE=browser
TRANSLATE_PROVIDER=mymemory          # mymemory | libretranslate
MYMEMORY_EMAIL=                      # optional: raises the free daily quota
LIBRETRANSLATE_URL=https://libretranslate.com
LIBRETRANSLATE_KEY=

# ---- Affiliate commission rates (%) by level ----
AFFILIATE_L1=30
AFFILIATE_L2=10
AFFILIATE_L3=5

# ---- Billing ----
# manual = activate plan immediately (bank transfer / testing).
# Switch to redsys/stripe once the gateway is wired (see docs/BILLING.md).
BILLING_MODE=manual

# ---- Initial admin (created by AdminUserSeeder) ----
ADMIN_NAME="Administrador"
ADMIN_EMAIL=gerencianovapasion@gmail.com
ADMIN_PASSWORD=Cambiar.1234
